---
type Props = {
  title: string;
  description?: string;
  image?: string;
  titleTemplate?: boolean;
};

const {
  title,
  description = "Experience Creator",
  image = "https://images.microcms-assets.io/assets/d1891ae6d53747678bd7870d6ea68f21/d061371d4f6d482da6e6c65e471cebc2/ogp.png",
  titleTemplate = true,
} = Astro.props;

const pageTitle = titleTemplate ? `${title} | andex.` : title;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JZ5PT8MLDQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-JZ5PT8MLDQ");
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Roboto Condensed";
    src: url("/font/RobotoCondensed-LightItalic.ttf") format("truetype");
    font-weight: 300;
    font-style: italic;
    font-display: swap;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, Roboto, "Segoe UI",
      "Helvetica Neue", HelveticaNeue, YuGothic, "Yu Gothic Medium", "Yu Gothic",
      Verdana, Meiryo, sans-serif;
    color: #1f1f1f;
  }

  h3 {
    font-size: 20pt;
    text-align: center;
    font-family: "Roboto Condensed";
    font-weight: 300;
    font-style: italic;
    margin-bottom: 10%;
  }

  @media screen and (max-width: 1024px) {
    h3 {
      font-size: 15pt;
    }
  }
</style>
